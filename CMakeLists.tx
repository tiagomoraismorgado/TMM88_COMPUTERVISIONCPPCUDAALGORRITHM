# ────────────────────────────────────────────────────────────────────────────────
#  Compiler options (host and device)
#  ────────────────────────────────────────────────────────────────────────────────

# Common flags for all targets
function(set_common_compile_options TARGET_NAME)
    target_compile_options(${TARGET_NAME}
        PRIVATE
            $<$<COMPILE_LANGUAGE:CXX>:-Wall -Wextra -Wpedantic -Wconversion -Wsign-conversion -Wshadow>
            $<$<COMPILE_LANGUAGE:CXX>:-Wno-unused-parameter -Wno-unused-function>
            $<$<COMPILE_LANGUAGE:CUDA>:-Xcompiler