# ────────────────────────────────────────────────────────────────────────────────
#  Source file organization (comprehensive)
#  ────────────────────────────────────────────────────────────────────────────────

# Root include directory
set(INCLUDE_DIR ${CMAKE_CURRENT_SOURCE_DIR}/include)
set(SRC_DIR ${CMAKE_CURRENT_SOURCE_DIR}/src)
set(KERNEL_DIR ${CMAKE_CURRENT_SOURCE_DIR}/kernels)
set(UTIL_DIR ${CMAKE_CURRENT_SOURCE_DIR}/utils)
set(REF_DIR ${CMAKE_CURRENT_SOURCE_DIR}/reference)

# Header files (modular organization)
set(HEADERS
    ${INCLUDE_DIR}/cuda_mad_exploits/config.h
    ${INCLUDE_DIR}/cuda_mad_exploits/types.h
    ${INCLUDE_DIR}/cuda_mad_exploits/macros.h
    ${INCLUDE_DIR}/cuda_mad_exploits/error_handling.h
    ${INCLUDE_DIR}/cuda_mad_exploits/cuda_utils.h
    ${INCLUDE_DIR}/cuda_mad_exploits/memory.h
    ${INCLUDE_DIR}/cuda_mad_exploits/pipeline.h
    ${INCLUDE_DIR}/cuda_mad_exploits/kernels.h
    ${INCLUDE_DIR}/cuda_mad_exploits/log_gabor.h
    ${INCLUDE_DIR}/cuda_mad_exploits/mad_metric.h
    ${INCLUDE_DIR}/cuda_mad_exploits/image_io.h
    ${INCLUDE_DIR}/cuda_mad_exploits/profiling.h
    ${INCLUDE_DIR}/cuda_mad_exploits/verification.h
    ${INCLUDE_DIR}/cuda_mad_exploits/fft_utils.h
    ${INCLUDE_DIR}/cuda_mad_exploits/math_utils.h
    ${INCLUDE_DIR}/cuda_mad_exploits/thread_pool.h
)

# Main source files
set(SOURCES
    ${SRC_DIR}/main.cu
    ${SRC_DIR}/pipeline_main.cu
    ${SRC_DIR}/gpu_pipeline.cu
    ${SRC_DIR}/gpu_pipeline_advanced.cu
    ${SRC_DIR}/utils.cu
    ${SRC_DIR}/cuda_utils.cu
    ${SRC_DIR}/memory_management.cu
    ${SRC_DIR}/error_handling.cpp
    ${SRC_DIR}/profiling.cpp
    ${SRC_DIR}/image_io.cpp
    ${SRC_DIR}/thread_pool.cpp
    ${SRC_DIR}/cpu_reference.cpp
    ${SRC_DIR}/verification.cpp
)

# Kernel source files (grouped by functionality)
file(GLOB KERNEL_SOURCES
    "${KERNEL_DIR}/*.cu"
)

# Utility source files (CPU-side helpers)
file(GLOB UTIL_SOURCES
    "${UTIL_DIR}/*.cpp"
)

# Reference implementation files (CPU validation)
file(GLOB REF_SOURCES
    "${REF_DIR}/*.cpp"
)

# Combine all sources
set(ALL_SOURCES
    ${HEADERS}
    ${SOURCES}
    ${KERNEL_SOURCES}
    ${UTIL_SOURCES}
    ${REF_SOURCES}
)

# Generate source groups for IDE organization
source_group("Include" FILES ${HEADERS})
source_group("Source" FILES ${SOURCES})
source_group("Kernels" FILES ${KERNEL_SOURCES})
source_group("Utils" FILES ${UTIL_SOURCES})
source_group("Reference" FILES ${REF_SOURCES})

# =============================================================================
#  ████████╗ █████╗ ██████╗  ██████╗ ███████╗████████╗███████╗
