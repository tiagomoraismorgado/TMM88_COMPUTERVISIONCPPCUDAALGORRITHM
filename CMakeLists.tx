# ────────────────────────────────────────────────────────────────────────────────
#  Core dependencies - OpenCV with component validation
#  ────────────────────────────────────────────────────────────────────────────────

find_package(OpenCV 4.8 REQUIRED
    COMPONENTS core imgproc highgui imgcodecs videoio calib3d features2d flann
    QUIET
)

# Validate OpenCV components
if(OpenCV_FOUND)
    message(STATUS "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    message(STATUS "OpenCV version:                ${OpenCV_VERSION}")
    message(STATUS "OpenCV include dirs:            ${OpenCV_INCLUDE_DIRS}")
    message(STATUS "OpenCV libraries:               ${OpenCV_LIBS}")
    message(STATUS "OpenCV modules:                 ${OpenCV_MODULES}")
    
    # Check for CUDA support in OpenCV (optional but beneficial)
    if(TARGET opencv_cudev)
        message(STATUS "OpenCV CUDA modules:           FOUND (cudev)")
        set(HAVE_OPENCV_CUDA ON)
    else()
        message(STATUS "OpenCV CUDA modules:           NOT FOUND (optional)")
    endif()
else()
    message(FATAL_ERROR "OpenCV 4.8+ is required for image I/O and processing")
endif()

# ────────────────────────────────────────────────────────────────────────────────
#  CUDA Toolkit with extended component detection
#  ────────────────────────────────────────────────────────────────────────────────

# CUDA is enabled via LANGUAGES CUDA — no find_package(CUDA) needed
# But we need the toolkit components
find_package(CUDAToolkit REQUIRED)

# Comprehensive CUDA component detection
set(CUDA_REQUIRED_COMPONENTS cufft)
set(CUDA_OPTIONAL_COMPONENTS 
    nvtx3 
    nvToolsExt 
    cudart 
    cuda_driver 
    nvml 
    cupti 
    cublas 
    cudnn
    curand
    cusolver
    cusparse
    nppc nppif nppisu nppicom nppidei nppist nppitc
)

foreach(COMP ${CUDA_OPTIONAL_COMPONENTS})
    find_package(CUDAToolkit COMPONENTS ${COMP} QUIET)
    if(CUDAToolkit_${COMP}_FOUND)
        set(HAVE_CUDA_${COMP} ON)
        message(STATUS "CUDA component ${COMP}:          FOUND")
    else()
        message(STATUS "CUDA component ${COMP}:          NOT FOUND (optional)")
    endif()
endforeach()

# ────────────────────────────────────────────────────────────────────────────────
#  NVTX handling (modern vs legacy) with fallback
#  ────────────────────────────────────────────────────────────────────────────────

if(ENABLE_NVTX)
    # Modern NVTX v3 (preferred since CUDA 10+)
    find_package(CUDAToolkit COMPONENTS nvtx3 QUIET)
    if(CUDAToolkit_nvtx3_FOUND)
        set(NVTX_MODE "MODERN")
        message(STATUS "NVTX support:                  MODERN (nvtx3)")
    else()
        message(WARNING "NVTX v3 not found — falling back to legacy nvToolsExt")
        find_package(CUDAToolkit COMPONENTS nvToolsExt QUIET)
        if(CUDAToolkit_nvToolsExt_FOUND)
            set(NVTX_MODE "LEGACY")
            message(STATUS "NVTX support:                  LEGACY (nvToolsExt)")
        else()
            set(ENABLE_NVTX OFF)
            message(STATUS "NVTX support:                  DISABLED (no libraries found)")
        endif()
    endif()
endif()

# ────────────────────────────────────────────────────────────────────────────────
#  Optional scientific computing libraries
#  ────────────────────────────────────────────────────────────────────────────────

find_package(FFTW3 QUIET)
if(FFTW3_FOUND)
    message(STATUS "FFTW3 found:                   ${FFTW3_VERSION}")
    set(HAVE_FFTW3 ON)
endif()

find_package(Eigen3 QUIET)
if(Eigen3_FOUND)
    message(STATUS "Eigen3 found:                  ${Eigen3_VERSION}")
    set(HAVE_EIGEN3 ON)
endif()

find_package(TBB QUIET)
if(TBB_FOUND)
    message(STATUS "Intel TBB found:                ${TBB_VERSION}")
    set(HAVE_TBB ON)
endif()

# ────────────────────────────────────────────────────────────────────────────────
#  Threading and concurrency libraries
#  ────────────────────────────────────────────────────────────────────────────────

find_package(Threads REQUIRED)
find_package(OpenMP QUIET)
if(OpenMP_FOUND)
    message(STATUS "OpenMP found:                   ${OpenMP_VERSION}")
    set(HAVE_OPENMP ON)
endif()

