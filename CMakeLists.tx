# ────────────────────────────────────────────────────────────────────────────────
#  Primary executable targets
#  ────────────────────────────────────────────────────────────────────────────────

# Main research executable (full pipeline)
add_executable(cuda_mad_exploits ${ALL_SOURCES})

# Lightweight test executable (unit tests)
add_executable(cuda_mad_tests
    ${INCLUDE_DIR}/cuda_mad_exploits/test_framework.h
    ${SRC_DIR}/tests/test_main.cu
    ${SRC_DIR}/tests/test_log_gabor.cu
    ${SRC_DIR}/tests/test_mad_metric.cu
    ${SRC_DIR}/tests/test_memory.cu
)

# Benchmark executable (performance measurement)
add_executable(cuda_mad_benchmarks
    ${INCLUDE_DIR}/cuda_mad_exploits/benchmark.h
    ${SRC_DIR}/benchmarks/bench_main.cu
    ${SRC_DIR}/benchmarks/bench_pipeline.cu
    ${SRC_DIR}/benchmarks/bench_kernels.cu
)

# Profiling executable (instrumented for Nsight)
add_executable(cuda_mad_profile
    ${ALL_SOURCES}
    ${SRC_DIR}/profiling/profiling_main.cu
)

# Validation executable (reference comparison)
if(ENABLE_VERIFY)
    add_executable(cuda_mad_validate
        ${ALL_SOURCES}
        ${SRC_DIR}/validation/validate_main.cu
        ${SRC_DIR}/validation/validate_pipeline.cu
    )
endif()

# Interactive explorer (GUI/visualization)
add_executable(cuda_mad_explorer
    ${ALL_SOURCES}
    ${SRC_DIR}/explorer/explorer_main.cu
    ${SRC_DIR}/explorer/visualization.cpp
)

