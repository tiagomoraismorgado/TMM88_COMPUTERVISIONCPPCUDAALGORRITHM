# ────────────────────────────────────────────────────────────────────────────────
#  Project-wide configuration management
#  ────────────────────────────────────────────────────────────────────────────────

# C++ standard configuration
set(CMAKE_CXX_STANDARD          17)
set(CMAKE_CXX_STANDARD_REQUIRED ON)
set(CMAKE_CXX_EXTENSIONS        OFF)

# CUDA standard configuration
set(CMAKE_CUDA_STANDARD          17)
set(CMAKE_CUDA_STANDARD_REQUIRED ON)
# set(CMAKE_CUDA_EXTENSIONS      OFF)   # usually left ON for __device__ / __global__ etc.

# Prefer modern separable compilation when device code calls other device code
set(CMAKE_CUDA_SEPARABLE_COMPILATION ON CACHE BOOL "Enable separable compilation for device-to-device calls" FORCE)

# Useful for Nsight Compute / profiling - keep line info even in Release
set(CMAKE_CUDA_LINE_INFO         ON  CACHE BOOL "Generate line info for profiling (Nsight Compute, Visual Profiler)" FORCE)

# Keep intermediate files for analysis
set(CMAKE_CUDA_KEEP_FILES        OFF CACHE BOOL "Keep intermediate CUDA files for debugging" FORCE)

# Default build type with comprehensive options
if(NOT CMAKE_BUILD_TYPE AND NOT CMAKE_CONFIGURATION_TYPES)
    set(CMAKE_BUILD_TYPE Release CACHE STRING "Build type: Debug, Release, RelWithDebInfo, MinSizeRel, Profile" FORCE)
    set_property(CACHE CMAKE_BUILD_TYPE PROPERTY STRINGS Debug Release RelWithDebInfo MinSizeRel Profile)
endif()

# ────────────────────────────────────────────────────────────────────────────────
#  Feature toggles and configuration options (extended)
#  ────────────────────────────────────────────────────────────────────────────────

# Core pipeline options
option(ENABLE_NVTX                "Enable NVTX profiling markers for NVIDIA NSight Systems" ON)
option(ENABLE_VERIFY              "Build verification / reference comparison code (CPU validation)" ON)
option(ENABLE_VERIFY_EXTENDED     "Extended verification with statistical analysis and regression tests" OFF)
option(USE_PINNED_MEMORY          "Use pinned host memory by default for faster transfers" ON)
option(USE_UNIFIED_MEMORY         "Use CUDA unified memory for simpler programming (experimental)" OFF)
option(USE_MANAGED_MEMORY         "Alias for USE_UNIFIED_MEMORY (backward compatibility)" OFF)

# Performance tuning
option(ENABLE_FAST_MATH           "Enable --use-fast-math for maximum performance (may reduce precision)" ON)
option(ENABLE_FTZ                  "Flush denormals to zero for performance" ON)
option(ENABLE_PTXAS_OPTIMIZATIONS  "Enable PTXAS optimizations" ON)
option(ENABLE_WARP_AGGREGATION     "Enable warp-level aggregation kernels" ON)
option(ENABLE_TENSOR_CORES         "Use Tensor Cores where applicable (requires compute 70+)" OFF)
option(ENABLE_CUDA_GRAPHS          "Use CUDA Graphs for kernel launch overhead reduction" ON)
option(ENABLE_MULTI_STREAM         "Enable multi-stream concurrency" ON)
option(ENABLE_DYNAMIC_PARALLELISM  "Enable CUDA dynamic parallelism for adaptive algorithms" OFF)

# Memory optimization
option(ENABLE_SHMEM_USAGE          "Use shared memory aggressively in kernels" ON)
option(ENABLE_LDG_CACHE            "Use read-only cache for global memory loads" ON)
option(ENABLE_COMPRESSED_MEMORY    "Use compressed memory access where supported" OFF)

# Debug and analysis
option(ENABLE_CUDA_DEBUG_INFO      "Generate full debug info for device code" OFF)
option(ENABLE_CUDA_LINE_INFO       "Generate line info (enabled by default for profiling)" ON)
option(ENABLE_CUDA_ANALYSIS        "Enable additional analysis tool support" OFF)
option(ENABLE_COMPUTE_SANITIZER    "Build with compute sanitizer support (memory checks)" OFF)
option(ENABLE_NSIGHT_COMPUTE       "Optimize for Nsight Compute analysis" ON)
option(ENABLE_CUPTI                 "Enable CUPTI-based profiling hooks" OFF)

# Numerical precision control
option(USE_FP32_PRECISION          "Use single precision for main pipeline" ON)
option(USE_FP16_PRECISION          "Use half precision for intermediate calculations" OFF)
option(USE_MIXED_PRECISION         "Use mixed precision strategies" OFF)
option(ENABLE_IEEE_STRICT          "Strict IEEE compliance (disables fast math)" OFF)

# Log-Gabor specific options
option(LOG_GABOR_USE_FAST_ATAN     "Use fast approximate atan2 in Gabor generation" ON)
option(LOG_GABOR_USE_FMA            "Use FMA instructions where beneficial" ON)
option(LOG_GABOR_OPTIMIZE_FILTERS   "Precompute and cache filter banks" ON)

# MAD metric options
option(MAD_USE_APPROXIMATE_SLOPE    "Use approximate slope calculations" ON)
option(MAD_USE_ADAPTIVE_SCALING     "Use adaptive scaling parameters" ON)
option(MAD_USE_GAUSSIAN_PYRAMID     "Use Gaussian pyramid for multi-scale analysis" ON)

# Output and logging
option(ENABLE_VERBOSE_LOGGING       "Enable verbose runtime logging" OFF)
option(ENABLE_PERFORMANCE_COUNTERS  "Track detailed performance counters" ON)
option(ENABLE_OUTPUT_IMAGES         "Generate output image files" ON)
option(ENABLE_METRIC_DUMP           "Dump metric values to CSV" OFF)

# Cross-platform support
option(ENABLE_LINUX_PERF            "Enable Linux perf event integration" ON)
option(ENABLE_WINDOWS_ETW            "Enable Windows ETW tracing" OFF)
option(ENABLE_MACOS_INSTRUMENTS      "Enable macOS Instruments support" OFF)

# ────────────────────────────────────────────────────────────────────────────────
#  Architecture configuration — extended for 2025–2026 hardware landscape
#  ────────────────────────────────────────────────────────────────────────────────

if(NOT DEFINED CMAKE_CUDA_ARCHITECTURES)
    # Comprehensive 2026 architecture support
    # From Tegra to Enterprise datacenter GPUs
    set(CMAKE_CUDA_ARCHITECTURES 
        70  # Volta (V100, T4) - foundational
        72  # Volta Tegra (Xavier)
        75  # Turing (RTX 20xx, T4 refresh)
        80  # Ampere (A100, RTX 30xx)
        86  # Ampere consumer (RTX 30xx)
        87  # Ampere mobile/laptop
        89  # Ada Lovelace (RTX 40xx) - current gen
        90  # Hopper (H100, H200) - datacenter
        90a # Hopper with Tensor Core MMA
        100 # Blackwell (B100, B200, RTX 50xx) - future gen
        CACHE STRING "CUDA architectures to compile for"
    )
endif()

# Architecture-specific feature detection
set(CUDA_ARCH_FEATURES "")
foreach(ARCH IN LISTS CMAKE_CUDA_ARCHITECTURES)
    string(REGEX REPLACE "[a-z]" "" ARCH_NUM ${ARCH})
    if(ARCH_NUM GREATER_EQUAL 70)
        list(APPEND CUDA_ARCH_FEATURES "CUDA_ARCH_VOLTA_PLUS")
    endif()
    if(ARCH_NUM GREATER_EQUAL 75)
        list(APPEND CUDA_ARCH_FEATURES "CUDA_ARCH_TURING_PLUS")
    endif()
    if(ARCH_NUM GREATER_EQUAL 80)
        list(APPEND CUDA_ARCH_FEATURES "CUDA_ARCH_AMPERE_PLUS")
    endif()
    if(ARCH_NUM GREATER_EQUAL 89)
        list(APPEND CUDA_ARCH_FEATURES "CUDA_ARCH_ADA_PLUS")
    endif()
    if(ARCH_NUM GREATER_EQUAL 90)
        list(APPEND CUDA_ARCH_FEATURES "CUDA_ARCH_HOPPER_PLUS")
    endif()
    if(ARCH_NUM GREATER_EQUAL 100)
        list(APPEND CUDA_ARCH_FEATURES "CUDA_ARCH_BLACKWELL_PLUS")
    endif()
endforeach()
list(REMOVE_DUPLICATES CUDA_ARCH_FEATURES)

