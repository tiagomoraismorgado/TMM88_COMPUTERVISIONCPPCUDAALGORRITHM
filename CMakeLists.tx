# ────────────────────────────────────────────────────────────────────────────────
#  Include directories (comprehensive)
#  ────────────────────────────────────────────────────────────────────────────────
target_include_directories(cuda_mad_exploits
    PRIVATE
        ${INCLUDE_DIR}
        ${CMAKE_CURRENT_SOURCE_DIR}
        ${OpenCV_INCLUDE_DIRS}
)

# Apply to all targets
foreach(TARGET IN ITEMS cuda_mad_exploits cuda_mad_tests cuda_mad_benchmarks cuda_mad_profile cuda_mad_explorer)
    if(TARGET ${TARGET})
        target_include_directories(${TARGET}
            PRIVATE
                ${INCLUDE_DIR}
                ${CMAKE_CURRENT_SOURCE_DIR}
                ${OpenCV_INCLUDE_DIRS}
        )
    endif()
endforeach()

if(TARGET cuda_mad_validate)
    target_include_directories(cuda_mad_validate
        PRIVATE
            ${INCLUDE_DIR}
            ${CMAKE_CURRENT_SOURCE_DIR}
            ${OpenCV_INCLUDE_DIRS}
    )
endif()

# ────────────────────────────────────────────────────────────────────────────────
#  Link libraries (comprehensive)
#  ────────────────────────────────────────────────────────────────────────────────
target_link_libraries(cuda_mad_exploits
    PRIVATE
        ${OpenCV_LIBS}
        CUDA::cufft
        Threads::Threads
)

# Add optional CUDA components
if(HAVE_CUDA_cublas)
    target_link_libraries(cuda_mad_exploits PRIVATE CUDA::cublas)
    target_compile_definitions(cuda_mad_exploits PRIVATE HAVE_CUBLAS)
endif()

if(HAVE_CUDA_cudnn)
    target_link_libraries(cuda_mad_exploits PRIVATE CUDA::cudnn)
    target_compile_definitions(cuda_mad_exploits PRIVATE HAVE_CUDNN)
endif()

if(HAVE_CUDA_curand)
    target_link_libraries(cuda_mad_exploits PRIVATE CUDA::curand)
    target_compile_definitions(cuda_mad_exploits PRIVATE HAVE_CURAND)
endif()

if(HAVE_CUDA_cusolver)
    target_link_libraries(cuda_mad_exploits PRIVATE CUDA::cusolver)
    target_compile_definitions(cuda_mad_exploits PRIVATE HAVE_CUSOLVER)
endif()

if(HAVE_CUDA_cusparse)
    target_link_libraries(cuda_mad_exploits PRIVATE CUDA::cusparse)
    target_compile_definitions(cuda_mad_exploits PRIVATE HAVE_CUSPARSE)
endif()

# NPP libraries (NVIDIA Performance Primitives)
if(HAVE_CUDA_nppc AND HAVE_CUDA_nppif AND HAVE_CUDA_nppisu)
    target_link_libraries(cuda_mad_exploits 
        PRIVATE 
            CUDA::nppc
            CUDA::nppif
            CUDA::nppisu
            CUDA::nppicom
            CUDA::nppidei
            CUDA::nppist
            CUDA::nppitc
    )
    target_compile_definitions(cuda_mad_exploits PRIVATE HAVE_NPP)
endif()

# NVTX support
if(ENABLE_NVTX)
    if(CUDAToolkit_nvtx3_FOUND)
        target_link_libraries(cuda_mad_exploits PRIVATE CUDA::nvtx3)
        target_compile_definitions(cuda_mad_exploits PRIVATE USE_NVTX3)
    elseif(CUDAToolkit_nvToolsExt_FOUND)
        target_link_libraries(cuda_mad_exploits PRIVATE CUDA::nvToolsExt)
        target_compile_definitions(cuda_mad_exploits PRIVATE USE_LEGACY_NVTX)
    endif()
endif()

# Optional scientific libraries
if(HAVE_FFTW3)
    target_link_libraries(cuda_mad_exploits PRIVATE FFTW3::fftw3)
    target_compile_definitions(cuda_mad_exploits PRIVATE HAVE_FFTW)
endif()

if(HAVE_EIGEN3)
    target_link_libraries(cuda_mad_exploits PRIVATE Eigen3::Eigen)
    target_compile_definitions(cuda_mad_exploits PRIVATE HAVE_EIGEN)
endif()

if(HAVE_TBB)
    target_link_libraries(cuda_mad_exploits PRIVATE TBB::tbb)
    target_compile_definitions(cuda_mad_exploits PRIVATE HAVE_TBB)
endif()

if(HAVE_OPENMP)
    target_link_libraries(cuda_mad_exploits PRIVATE OpenMP::OpenMP_CXX)
endif()

# Apply similar linking to all targets
foreach(TARGET IN ITEMS cuda_mad_tests cuda_mad_benchmarks cuda_mad_profile cuda_mad_explorer cuda_mad_validate)
    if(TARGET ${TARGET})
        target_link_libraries(${TARGET}
            PRIVATE
                ${OpenCV_LIBS}
                CUDA::cufft
                Threads::Threads
        )
        
        # Copy over all optional libraries
        get_target_property(EXPLOITS_LIBS cuda_mad_exploits LINK_LIBRARIES)
        if(EXPLOITS_LIBS)
            target_link_libraries(${TARGET} PRIVATE ${EXPLOITS_LIBS})
        endif()
    endif()
endforeach()

