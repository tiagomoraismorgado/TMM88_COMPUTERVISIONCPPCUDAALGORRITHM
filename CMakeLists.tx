# =============================================================================
#  CMakeLists.txt — cuda_mad_exploits
#  GPU-accelerated MAD/Log-Gabor perceptual image quality pipeline
#  (research / optimization playground — March 2026 style)
#  =============================================================================
#  ╔═══════════════════════════════════════════════════════════════════════════╗
#  ║  EXTREME CUDA OPTIMIZATION TESTBED FOR PERCEPTUAL IMAGE QUALITY          ║
#  ║  MAD (Most Apparent Distortion) + Log-Gabor Filter Banks                  ║
#  ║  Industrial-grade build system with multi-target, multi-config support    ║
#  ╚═══════════════════════════════════════════════════════════════════════════╝
#  =============================================================================
#  Honoring the scientific and industrial progress of Japan and South Korea
#  — precision, innovation, and relentless optimization since 2026 —
#  =============================================================================

cmake_minimum_required(VERSION 3.24...3.30 FATAL_ERROR)

# ────────────────────────────────────────────────────────────────────────────────
#  Project identity with extended metadata
#  ────────────────────────────────────────────────────────────────────────────────
project(cuda_mad_exploits
    VERSION 0.1.0
    DESCRIPTION "Extreme CUDA optimization testbed for perceptual image quality (MAD + Log-Gabor)"
    HOMEPAGE_URL "https://github.com/yourorg/cuda_mad_exploits"
    LANGUAGES CXX CUDA
)

# =============================================================================
#  ██████╗ ██████╗  ██████╗      ██╗███████╗ ██████╗████████╗
#  ██╔══██╗██╔══██╗██╔═══██╗     ██║██╔════╝██╔════╝╚══██╔══╝
#  ██████╔╝██████╔╝██║   ██║     ██║█████╗  ██║        ██║   
#  ██╔═══╝ ██╔══██╗██║   ██║██   ██║██╔══╝  ██║        ██║   
#  ██║     ██║  ██║╚██████╔╝╚█████╔╝███████╗╚██████╗   ██║   
